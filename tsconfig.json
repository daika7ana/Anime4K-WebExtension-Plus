{
  "compilerOptions": {
    "target": "es2022",
    "module": "node20",
    "moduleResolution": "node16",
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedSideEffectImports": false,
    "lib": [
      "es2022",
      "dom"
    ],
    "types": ["chrome"]
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}